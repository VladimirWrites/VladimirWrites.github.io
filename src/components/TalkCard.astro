---
interface Props {
  title: string;
  description: string;
  date: Date;
  image?: string;
  slug: string;
}

const { title, description, date, image, slug } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  month: 'short',
  day: '2-digit',
  year: 'numeric',
});
---
<div class="card">
  <a href={`/${slug}/`}>
    {image && <img class="card-image" src={image} alt={title} loading="lazy" />}
    <div class="card-body">
      <p class="card-date">{formattedDate}</p>
      <h3>{title}</h3>
      {description && <p class="card-description">{description}</p>}
    </div>
  </a>
</div>
