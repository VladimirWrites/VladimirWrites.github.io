---
import PageLayout from '../layouts/PageLayout.astro';
import SocialLinks from '../components/SocialLinks.astro';
---
<PageLayout currentPage="Home" description="Vladimir Jovanović — Android Developer">
  <section class="hero">
    <h1 class="hero-name">
      Vladimir<br />
      <span class="hero-gradient">Jovanović</span>
    </h1>
    <p class="hero-tagline">Android Developer</p>
    <p class="hero-description">
      Building clean, stable mobile experiences since Android 2.2.
      Senior Engineer, Course Author, and Conference Speaker.
    </p>
    <SocialLinks />
  </section>
</PageLayout>
