---
const title = 'Getting Started with Android Studio';
const description = 'Android Studio is a great IDE for Android developers. This course takes you through the most important features and prepares you for the joyous and rewarding journey of becoming an Android developer.';
const image = 'https://pluralsight.imgix.net/course-images/android-studio-getting-started-v1.png';
const redirectUrl = 'https://pluralsight.pxf.io/L3QOj';
---
<!DOCTYPE html>
<html>
<head>
  <title>Redirecting...</title>
  <meta property="twitter:card" content="summary_large_image"/>
  <meta property="twitter:title" content={title}/>
  <meta property="twitter:description" content={description}/>
  <meta property="twitter:url" content={redirectUrl}/>
  <meta property="twitter:image:src" content={image}/>
  <meta property="og:title" content={title} />
  <meta property="og:url" content={redirectUrl} />
  <meta property="og:image" content={image} />
  <meta property="og:description" content={description} />
  <link rel="canonical" href={redirectUrl}/>
  <noscript>
    <meta http-equiv="refresh" content={`0;url=${redirectUrl}`} />
  </noscript>
</head>
<body>
  <script is:inline define:vars={{ redirectUrl }}>
    window.opener = null;
    location.replace(redirectUrl);
  </script>
</body>
</html>
